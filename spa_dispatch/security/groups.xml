<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_spa_user" model="res.groups">
        <field name="name">Spa: Team Member</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="comment">Can view and update their own appointments in the field.</field>
    </record>

    <record id="group_spa_agent" model="res.groups">
        <field name="name">Spa: Booking Agent</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('group_spa_user'))]"/>
        <field name="comment">Can create and manage appointments, assign cars and teams.</field>
    </record>

    <record id="group_spa_manager" model="res.groups">
        <field name="name">Spa: Manager</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('group_spa_agent'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        <field name="comment">Full access to all spa dispatch records and configuration.</field>
    </record>

</odoo>
