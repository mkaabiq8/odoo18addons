<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Search ── -->
    <record id="view_spa_appointment_search" model="ir.ui.view">
        <field name="name">spa.appointment.search</field>
        <field name="model">spa.appointment</field>
        <field name="arch" type="xml">
            <search string="Appointments">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="phone" string="Phone / Mobile"/>
                <field name="car_id" string="Zone"/>
                <field name="team_id"/>
                <field name="agent_id"/>
                <field name="state_id" string="State / Area"/>
                <field name="city_id" string="City"/>
                <filter string="Today" name="today"
                        domain="[('service_date', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0))),
                                 ('service_date', '&lt;=', datetime.datetime.combine(context_today(), datetime.time(23,59,59)))]"/>
                <filter string="This Week" name="this_week"
                        domain="[('service_date', '&gt;=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="Pending"     name="draft"       domain="[('status','=','draft')]"/>
                <filter string="Confirmed"   name="confirmed"   domain="[('status','=','confirmed')]"/>
                <filter string="Traveling"   name="traveling"   domain="[('status','=','traveling')]"/>
                <filter string="In Progress" name="in_progress" domain="[('status','=','in_progress')]"/>
                <filter string="Completed"   name="done"        domain="[('status','=','done')]"/>
                <filter string="Cancelled"   name="cancelled"   domain="[('status','=','cancelled')]"/>
                <separator/>
                <filter string="My Appointments" name="my_appointments"
                        domain="['|', ('agent_id','=',uid), ('technician_ids','=',uid)]"/>
                <group expand="0" string="Group By">
                    <filter string="Zone"      name="group_car"    context="{'group_by': 'car_id'}"/>
                    <filter string="Team"      name="group_team"   context="{'group_by': 'team_id'}"/>
                    <filter string="Status"    name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="State"     name="group_state"  context="{'group_by': 'state_id'}"/>
                    <filter string="City"      name="group_city"   context="{'group_by': 'city_id'}"/>
                    <filter string="Date"      name="group_date"   context="{'group_by': 'service_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── List ── -->
    <record id="view_spa_appointment_list" model="ir.ui.view">
        <field name="name">spa.appointment.list</field>
        <field name="model">spa.appointment</field>
        <field name="arch" type="xml">
            <list string="Appointments" decoration-success="status=='done'"
                  decoration-danger="status=='cancelled'"
                  decoration-info="status in ('traveling','arrived','in_progress')"
                  decoration-muted="status=='draft'">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="phone"/>
                <field name="service_date"/>
                <field name="duration"/>
                <field name="car_id" string="Zone"/>
                <field name="team_slot"/>
                <field name="team_id"/>
                <field name="state_id" optional="show"/>
                <field name="city_id" optional="show"/>
                <field name="address"/>
                <field name="total_amount" sum="Total"/>
                <field name="status" widget="badge"
                       decoration-success="status=='done'"
                       decoration-danger="status=='cancelled'"
                       decoration-info="status in ('traveling','arrived','in_progress')"
                       decoration-warning="status=='confirmed'"/>
                <field name="priority" widget="priority"/>
            </list>
        </field>
    </record>

    <!-- ── Form ── -->
    <record id="view_spa_appointment_form" model="ir.ui.view">
        <field name="name">spa.appointment.form</field>
        <field name="model">spa.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointment">
                <header>
                    <!-- Agent workflow -->
                    <button name="action_confirm" type="object" string="Confirm"
                            class="btn-primary"
                            invisible="status not in ['draft']"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="status in ['done','cancelled']"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            invisible="status not in ['cancelled']"/>
                    <!-- Field team workflow -->
                    <button name="action_traveling" type="object" string="We're Traveling"
                            class="btn-primary"
                            invisible="status not in ['confirmed']"/>
                    <button name="action_arrived" type="object" string="We've Arrived"
                            class="btn-primary"
                            invisible="status not in ['traveling']"/>
                    <button name="action_start" type="object" string="Start Session"
                            class="btn-primary"
                            invisible="status not in ['arrived']"/>
                    <button name="action_done" type="object" string="Complete"
                            class="btn-success"
                            invisible="status not in ['in_progress']"/>
                    <!-- Payment link -->
                    <button name="action_generate_payment_link" type="object"
                            string="Generate Payment Link"
                            class="btn-secondary"
                            invisible="status == 'cancelled'"/>
                    <!-- Driver route -->
                    <button name="action_driver_route" type="object" string="Driver Route"
                            class="btn-secondary"
                            invisible="not car_id"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,confirmed,traveling,arrived,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <field name="priority" widget="priority"/>
                    </div>
                    <group>
                        <!-- Customer -->
                        <group string="Customer">
                            <field name="customer_id"/>
                            <field name="phone"/>
                            <field name="crm_lead_id" optional="show"/>
                        </group>
                        <!-- Scheduling -->
                        <group string="Schedule">
                            <field name="service_date"/>
                            <field name="duration"/>
                            <field name="service_end_date" readonly="1"/>
                            <field name="agent_id"/>
                        </group>
                    </group>
                    <group>
                        <!-- Dispatch -->
                        <group string="Dispatch">
                            <field name="car_id" string="Zone"/>
                            <field name="team_slot"/>
                            <field name="team_id"
                                   domain="[('car_id','=',car_id),('slot','=',team_slot)]"/>
                            <field name="driver_id" readonly="1"/>
                        </group>
                        <!-- Team -->
                        <group string="Team Members">
                            <field name="technician_ids" widget="many2many_tags" readonly="1"/>
                        </group>
                    </group>
                    <!-- Location -->
                    <group string="Location">
                        <group>
                            <field name="state_id"/>
                            <field name="city_id"
                                   domain="[('state_id','=',state_id)]"/>
                            <field name="address"/>
                        </group>
                        <group>
                            <field name="google_map_link" widget="url"
                                   placeholder="https://maps.google.com/..."/>
                        </group>
                    </group>
                    <!-- Customer Notes (visible directly on form) -->
                    <group string="Customer Notes">
                        <field name="customer_notes"
                               placeholder="Customer preferences, allergies, special requests..."
                               nolabel="1"/>
                    </group>
                    <!-- Services -->
                    <notebook>
                        <page string="Services" name="services">
                            <field name="service_line_ids">
                                <list editable="bottom">
                                    <field name="service_id"/>
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="subtotal" readonly="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_amount" string="Total" readonly="1"
                                       widget="monetary"/>
                            </group>
                        </page>
                        <page string="Internal Notes" name="notes">
                            <field name="notes" placeholder="Internal notes..." nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Calendar ── -->
    <record id="view_spa_appointment_calendar" model="ir.ui.view">
        <field name="name">spa.appointment.calendar</field>
        <field name="model">spa.appointment</field>
        <field name="arch" type="xml">
            <calendar string="Appointments" date_start="service_date" date_stop="service_end_date"
                      color="car_id" mode="week" quick_create="False">
                <field name="customer_id" string="Customer"/>
                <field name="car_id" string="Zone"/>
                <field name="city_id" string="City"/>
                <field name="team_slot"/>
                <field name="status"/>
            </calendar>
        </field>
    </record>

    <!-- ── Kanban (by status) ── -->
    <record id="view_spa_appointment_kanban" model="ir.ui.view">
        <field name="name">spa.appointment.kanban</field>
        <field name="model">spa.appointment</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column"
                    quick_create="False">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="service_date"/>
                <field name="car_id"/>
                <field name="team_slot"/>
                <field name="team_id"/>
                <field name="state_id"/>
                <field name="city_id"/>
                <field name="address"/>
                <field name="status"/>
                <field name="color"/>
                <field name="total_amount"/>
                <field name="priority"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <field name="priority" widget="priority"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div><b><field name="customer_id"/></b></div>
                                    <div>
                                        <i class="fa fa-calendar"/> <field name="service_date"/>
                                    </div>
                                    <div>
                                        <i class="fa fa-map-marker"/>
                                        <t t-if="record.city_id.raw_value">
                                            <field name="city_id"/>
                                            <t t-if="record.state_id.raw_value"> — <field name="state_id"/></t>
                                        </t>
                                        <t t-else="">
                                            <field name="address"/>
                                        </t>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <span class="badge bg-primary">
                                        <field name="car_id"/>
                                    </span>
                                    <span t-if="record.team_slot.raw_value" class="badge bg-secondary ms-1">
                                        Team <t t-esc="record.team_slot.raw_value.toUpperCase()"/>
                                    </span>
                                    <span class="ms-auto">
                                        <field name="total_amount" widget="monetary"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── Action ── -->
    <record id="action_spa_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">spa.appointment</field>
        <field name="view_mode">list,kanban,calendar,form</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Book your first appointment!
            </p>
            <p>
                Create a new appointment, assign a car and team, and track the service from booking to completion.
            </p>
        </field>
    </record>

    <!-- ── Team status wizard view ── -->
    <record id="view_team_status_wizard_form" model="ir.ui.view">
        <field name="name">spa.team.status.wizard.form</field>
        <field name="model">spa.team.status.wizard</field>
        <field name="arch" type="xml">
            <form string="Update Appointment Status">
                <sheet>
                    <group>
                        <field name="appointment_id" readonly="1"/>
                        <field name="customer_name" readonly="1"/>
                        <field name="address" readonly="1"/>
                        <field name="current_status" readonly="1"/>
                    </group>
                    <group string="Update">
                        <field name="new_status"/>
                        <field name="note"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_apply" type="object" string="Update Status" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
