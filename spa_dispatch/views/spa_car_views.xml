<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List ── -->
    <record id="view_spa_car_list" model="ir.ui.view">
        <field name="name">spa.car.list</field>
        <field name="model">spa.car</field>
        <field name="arch" type="xml">
            <list string="Vehicles">
                <field name="name"/>
                <field name="driver_id"/>
                <field name="team_a_id"/>
                <field name="team_b_id"/>
                <field name="today_appointment_count" string="Today"/>
                <field name="appointment_count" string="Total"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ── Form ── -->
    <record id="view_spa_car_form" model="ir.ui.view">
        <field name="name">spa.car.form</field>
        <field name="model">spa.car</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <header>
                    <button name="action_view_appointments" type="object"
                            string="View Appointments" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_appointments" type="object"
                                class="oe_stat_button" icon="fa-calendar">
                            <field name="appointment_count" widget="statinfo" string="Appointments"/>
                        </button>
                        <button name="action_view_appointments" type="object"
                                class="oe_stat_button" icon="fa-sun-o">
                            <field name="today_appointment_count" widget="statinfo" string="Today"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Vehicle name..."/></h1>
                    </div>
                    <group>
                        <group string="Vehicle Info">
                            <field name="driver_id"/>
                            <field name="active"/>
                        </group>
                        <group string="Teams">
                            <field name="team_a_id" readonly="1"/>
                            <field name="team_b_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Teams" name="teams">
                            <field name="team_ids">
                                <list editable="bottom">
                                    <field name="slot"/>
                                    <field name="name"/>
                                    <field name="member_ids" widget="many2many_tags"/>
                                    <field name="appointment_count" string="Appointments"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Kanban ── -->
    <record id="view_spa_car_kanban" model="ir.ui.view">
        <field name="name">spa.car.kanban</field>
        <field name="model">spa.car</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="name"/>
                <field name="driver_id"/>
                <field name="today_appointment_count"/>
                <field name="appointment_count"/>
                <field name="color"/>
                <templates>
                    <t t-name="kanban-card">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="o_kanban_record_body">
                                    <span>Driver: <field name="driver_id"/></span>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <span class="badge bg-info">
                                        <field name="today_appointment_count"/> today
                                    </span>
                                    <span class="badge bg-secondary ms-1">
                                        <field name="appointment_count"/> total
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── Action ── -->
    <record id="action_spa_car" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">spa.car</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

</odoo>
