<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List ── -->
    <record id="view_spa_city_list" model="ir.ui.view">
        <field name="name">spa.city.list</field>
        <field name="model">spa.city</field>
        <field name="arch" type="xml">
            <list string="Cities">
                <field name="name"/>
                <field name="state_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ── Form ── -->
    <record id="view_spa_city_form" model="ir.ui.view">
        <field name="name">spa.city.form</field>
        <field name="model">spa.city</field>
        <field name="arch" type="xml">
            <form string="City">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="City name..."/></h1>
                    </div>
                    <group>
                        <field name="state_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ── -->
    <record id="action_spa_city" model="ir.actions.act_window">
        <field name="name">Cities</field>
        <field name="res_model">spa.city</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
