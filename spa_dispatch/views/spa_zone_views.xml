<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List ── -->
    <record id="view_spa_zone_list" model="ir.ui.view">
        <field name="name">spa.zone.list</field>
        <field name="model">spa.zone</field>
        <field name="arch" type="xml">
            <list string="Zones">
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ── Form ── -->
    <record id="view_spa_zone_form" model="ir.ui.view">
        <field name="name">spa.zone.form</field>
        <field name="model">spa.zone</field>
        <field name="arch" type="xml">
            <form string="Zone / Area">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Zone name..."/></h1>
                    </div>
                    <group>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="notes" placeholder="Internal notes..." nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ── -->
    <record id="action_spa_zone" model="ir.actions.act_window">
        <field name="name">Zones</field>
        <field name="res_model">spa.zone</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
