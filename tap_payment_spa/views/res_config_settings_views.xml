<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_tap_payment" model="ir.ui.view">
        <field name="name">res.config.settings.tap.payment</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="before">
                <div class="app_settings_block" string="Tap Payment" data-string="Tap Payment"
                     data-key="tap_payment_spa">
                    <h2>Tap Payment Integration</h2>
                    <div class="row mt16 o_settings_container">

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Test Mode</span>
                                <div class="text-muted">
                                    Enable sandbox mode (use sk_test_xxx keys).
                                    Disable for live production payments.
                                </div>
                                <div class="content-group mt8">
                                    <field name="tap_test_mode" widget="boolean_toggle"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="tap_secret_key" class="o_form_label">Secret Key</label>
                                <div class="text-muted">
                                    Backend key (sk_live_xxx / sk_test_xxx). Keep private.
                                </div>
                                <div class="content-group mt8">
                                    <field name="tap_secret_key" password="True"
                                           placeholder="sk_test_xxxxxxxxxxxx"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="tap_public_key" class="o_form_label">Public Key</label>
                                <div class="text-muted">
                                    Frontend key (pk_live_xxx / pk_test_xxx).
                                </div>
                                <div class="content-group mt8">
                                    <field name="tap_public_key"
                                           placeholder="pk_test_xxxxxxxxxxxx"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="tap_merchant_id" class="o_form_label">Merchant ID</label>
                                <div class="text-muted">
                                    From Tap Dashboard → Accounts → Operators.
                                </div>
                                <div class="content-group mt8">
                                    <field name="tap_merchant_id"
                                           placeholder="merchant_xxxxxxxx"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="tap_redirect_url" class="o_form_label">
                                    Payment Return URL
                                </label>
                                <div class="text-muted">
                                    Leave blank to use default:
                                    <code>&lt;base_url&gt;/tap/payment/return</code>
                                </div>
                                <div class="content-group mt8">
                                    <field name="tap_redirect_url"
                                           placeholder="https://yourodoo.com/tap/payment/return"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="tap_webhook_url" class="o_form_label">
                                    Webhook URL
                                </label>
                                <div class="text-muted">
                                    Tap POSTs payment results here. Leave blank to use default:
                                    <code>&lt;base_url&gt;/tap/payment/webhook</code>
                                </div>
                                <div class="content-group mt8">
                                    <field name="tap_webhook_url"
                                           placeholder="https://yourodoo.com/tap/payment/webhook"/>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
